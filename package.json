{
  "name": "astrotribe",
  "license": "MIT",
  "private": true,
  "type": "module",
  "version": "0.0.4",
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "typescript": {
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },
  "scripts": {
    "dump:data": "supabase db dump -f supabase/data-backup.sql --data-only",
    "dump:schema": "supabase db dump -f supabase/schema-backup.sql",
    "freesh": "pnpm clean && pnpm init",
    "init": "supabase start && pnpm db:setup",
    "clean": "scripts/speed/clean.sh",
    "debug": "./scripts/debug-build.sh",
    "install:all": "pnpm install --workspaces",
    "page-repomix": "pnpx tsx ./scripts/bundler/bin/exec.ts",
    "gen:api": "pnpx tsx scripts/api/create-api",
    "dev:cron": "turbo run dev --filter=@astronera/cron-jobs",
    "dev:api": "turbo run dev --filter=@astronera/api",
    "dev:auth": "turbo run dev --filter=@astronera/auth",
    "dev:admin": "turbo run dev --filter=@astronera/admin --filter=@astronera/auth",
    "dev:app": "turbo run dev --filter=@astronera/app --filter=@astronera/auth",
    "dev:website": "turbo run dev --filter=@astronera/website",
    "dev:front": "NUXT_MULTI_APP=true turbo run dev --filter=@astronera/admin --filter=@astronera/app --filter=@astronera/auth",
    "dev:back": "NUXT_MULTI_APP=true turbo run dev --filter=@astronera/api --filter=@astronera/cron-jobs",
    "dev:all": "NUXT_MULTI_APP=true turbo run dev --filter=@astronera/auth --filter=@astronera/app --filter=@astronera/admin --filter=@astronera/api",
    "docker:all": "pnpx tsx ./ci/2.build-docker-containers.ts",
    "build:layers": "scripts/build-layers.sh",
    "build:website": "turbo run build --filter=@astronera/website && NODE_ENV=development node ./apps/website/.output/server/index.mjs",
    "build:app": "turbo run build --filter=@astronera/app --filter=@astronera/auth",
    "build:auth": "turbo run build --filter=@astronera/auth",
    "build:admin": "turbo run build --filter=@astronera/admin",
    "build:all": "pnpx tsx ./ci/1.build-with-logs.ts",
    "db:migrate:prep": "pnpx tsx scripts/db/migrate/pre-migration.ts",
    "db:migrate": "pnpx tsx scripts/db/migrate/1.perform-migration.ts",
    "db:setup": "pnpx tsx scripts/db/init/2.main.ts",
    "db:clean": "pnpx tsx ./scripts/db/db-cleanup.ts",
    "db:backup": "tsx scripts/db/backup/index.ts",
    "db:backup:csv": "tsx scripts/db/backup/index.ts --data-only --export-format=csv --verbose",
    "db:backup:bulk": "tsx scripts/db/backup/index.ts --data-only --export-format=bulk-inserts --bulk-insert-size=250 --verbose",
    "db:backup:json": "tsx scripts/db/backup/index.ts --data-only --export-format=json --verbose",
    "db:backup:schema": "tsx scripts/db/backup/index.ts --schema-only --verbose",
    "db:rls:debug": "tsx scripts/debug/rls-debug.ts",
    "db:rls:validate": "tsx scripts/db/rls-validation/index.ts",
    "db:test:verbose": "tsx scripts/db/testing/rls-validation/index.ts --verbose",
    "db:test:json": "tsx scripts/db/testing/rls-validation/index.ts --json",
    "db:test:html": "tsx scripts/db/testing/rls-validation/index.ts --html",
    "db:test:critical": "tsx scripts/db/testing/rls-validation/index.ts --only-tables user_profiles,customer_payments,customer_subscriptions",
    "db:test:fail-fast": "tsx scripts/db/testing/rls-validation/index.ts --fail-fast --verbose",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,vue,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,jsx,tsx,vue,json,md,yml,yaml}\"",
    "types": "turbo run typecheck --filter=@astronera/crud",
    "clean:nuxi": "scripts/nuxi-cleanup.sh",
    "staging": "railway link -p d2993a83-20e2-4658-b045-8202866cd11f",
    "ai:docs": "./scripts/docs-manager.sh",
    "ai:package": "pnpx tsx cli/index.ts",
    "ai:scan": "./scripts/scan-projects.sh",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "ib:permissions": "pnpx tsx cli/update-rba-permissions.ts",
    "pack:feature": "pnpx tsx scripts/bundler/bundler-cli.ts search",
    "bundle": "pnpx tsx scripts/bundler/bundler-cli.ts",
    "bundle:debug": "DEBUG=true npx tsx scripts/bundler/bundler-cli.ts",
    "ib": "pnpx tsx cli/index.ts",
    "pg:migrate": "pnpm --filter @astronera/pg-service migrate",
    "pg:backup": "pnpm --filter @astronera/pg-service backup",
    "pg:restore": "pnpm --filter @astronera/pg-service restore",
    "website:setup": "./apps/pg-service/scripts/generate-init-files.sh && docker compose -f docker-compose.website.yaml down -v && docker compose -f docker-compose.website.yaml up -d --build",
    "website:dev": "docker compose -f docker-compose.website.yaml up -d"
  },
  "dependencies": {
    "@iconify-json/game-icons": "^1.2.1",
    "@iconify-json/lucide": "^1.2.37",
    "@iconify-json/material-symbols": "^1.2.1",
    "@iconify-json/mdi": "^1.2.0",
    "@nuxt/eslint": "^0.7.5",
    "@nuxt/fonts": "^0.11.2",
    "@nuxt/icon": "^1.5.1",
    "@nuxt/image": "^1.10.0",
    "@nuxt/kit": "^3.15.0",
    "@nuxt/schema": "^3.15.0",
    "@nuxtjs/mdc": "^0.12.0",
    "@nuxtjs/supabase": "^1.5.0",
    "@nuxtjs/tailwindcss": "^6.12.1",
    "@pinia/nuxt": "^0.9.0",
    "@primevue/core": "^4.3.3",
    "@primevue/nuxt-module": "^4.3.3",
    "@primevue/themes": "^4.3.3",
    "@sentry/vue": "^8.31.0",
    "@supabase/supabase-js": "^2.47.8",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "20.14.8",
    "@vueuse/core": "^12.3.0",
    "@vueuse/integrations": "^12.3.0",
    "@vueuse/nuxt": "^12.3.0",
    "chalk": "^5.3.0",
    "change-case": "^5.4.4",
    "chart.js": "^4.4.4",
    "consola": "^3.3.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "embla-carousel-auto-scroll": "^8.5.2",
    "embla-carousel-autoplay": "^8.3.0",
    "embla-carousel-vue": "^8.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "fuse.js": "^7.0.0",
    "gsap": "^3.12.5",
    "h3": "^1.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-lame": "^1.3.2",
    "nuxt": "^3.16.1",
    "nuxt-security": "^2.0.0",
    "ofetch": "^1.4.0",
    "openai": "^4.89.0",
    "pdf-lib": "^1.17.1",
    "pg-pool": "^3.7.0",
    "pinia": "^2.2.2",
    "postcss": "^8.4.47",
    "posthog-js": "^1.164.3",
    "primevue": "^4.3.3",
    "qrcode": "^1.5.4",
    "quill": "^2.0.3",
    "resend": "^4.0.1",
    "robots-parser": "^3.0.1",
    "rollup": "^4.14.0",
    "rss-parser": "^3.13.0",
    "sass": "^1.79.3",
    "scule": "^1.3.0",
    "shiki": "^1.22.0",
    "stacktrace-parser": "^0.1.10",
    "tailwindcss": "^3.4.13",
    "tailwindcss-primeui": "^0.5.1",
    "ts-morph": "^25.0.0",
    "turbo": "latest",
    "typescript": "^5.6.3",
    "uuid": "^10.0.0",
    "vite": "^6.2.2",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "vue-tsc": "~2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nuxt/devtools": "^2.3.1",
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/test-utils": "^3.14.4",
    "@nuxt/ui-templates": "^1.3.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "@types/pg-pool": "^2.0.6",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "@vue/eslint-config-prettier": "10.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.16.1",
    "happy-dom": "^15.11.6",
    "nuxi": "^3.17.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "repomix": "^0.2.2",
    "tsx": "^4.7.0",
    "typescript-eslint": "^8.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.9",
    "vue-advanced-cropper": "^2.8.9"
  },
  "resolutions": {
    "cookie": "0.7.2"
  },
  "pnpm": {
    "overrides": {
      "vue-tsc": "~2.1.6"
    },
    "peerDependencyRules": {
      "allowAny": [
        "@astronera/*"
      ]
    }
  }
}
