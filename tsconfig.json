{
  "files": [],
  "compilerOptions": {
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "#layers/*": ["layers/*"]
    }
  },
  "references": [
    { "path": "shared" },
    // Applications
    { "path": "apps/api" },
    { "path": "apps/chrome-extension" },

    // Nuxt Applications
    { "path": "apps/website" },
    { "path": "apps/app" },
    { "path": "apps/admin" },
    { "path": "apps/auth" },

    // Nuxt Layers
    { "path": "layers/base" },
    { "path": "layers/crud" },
    { "path": "layers/advert" },
    { "path": "layers/supabase" }
  ],
  "include": ["prettier.config.mjs", "shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
